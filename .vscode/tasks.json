{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Git Pull on Open",
      "type": "shell",
      "command": "git pull",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": ["-c"]
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      }
    }
  ]
}
